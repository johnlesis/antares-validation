{
    "name": "fatjon-lleshi/antares-validation",
    "description": "Lightweight DTO hydration and validation for PHP 8.2+",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Antares\\Validation\\": "src/Validation/",
            "Antares\\Hydration\\": "src/Hydration/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Antares\\Tests\\Validation\\": "tests/Validation/",
            "Antares\\Tests\\Hydration\\": "tests/Hydration/"
        }
    },
    "authors": [
        {
            "name": "Fatjon Lleshi",
            "email": "johnlesis91@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "psr/http-message": "^1.0|^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "phpstan/phpstan": "^2.0"
    }
}